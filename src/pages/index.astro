---
import FloatingMenu from "./FloatingMenu.astro";
import Layout from "./Layout.astro";
---

<Layout title="Modern Floating Grid Menu">
  <main class="hero slide-anim">
    <header class="title-container">
      <div class="hero-icon" aria-hidden="true">
        <i class="fa-solid fa-code-branch"></i>
      </div>
      <h1>Software Development</h1>
      <p class="author">Cesar Eduardo Castañeda López</p>
    </header>

    <div class="menu-wrapper">
      <FloatingMenu />
    </div>
  </main>
</Layout>

<style>
  .hero {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    min-height: 50vh;
  }

  .hero-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    margin: 0 auto 1rem;
    border-radius: 16px;
    background: linear-gradient(135deg, #2563eb, #7c3aed);
    color: white;
    box-shadow: 0 18px 35px rgba(37, 99, 235, 0.22);
    font-size: 1.5rem;
  }

  .title-container h1 {
    font-size: 3.8rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 0.5rem;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, #0f172a 0%, #2563eb 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .title-container .author {
    font-size: 1.2rem;
    font-weight: 500;
    color: #64748b;
    letter-spacing: 0.02em;
  }

  .menu-wrapper {
    opacity: 0;
    transform: scale(0.95);
    animation: fadeInScale 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
    margin-top: 90px;
  }

  @keyframes fadeInScale {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>
